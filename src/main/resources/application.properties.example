server.address=0.0.0.0
# 8443 for https and 8080 for http
server.port=8080
server.forward-headers-strategy=framework

# "dev" for development "prod" for production
spring.profiles.active=dev
spring.application.name=monitor

spring.datasource.url=jdbc:postgresql://localhost:5432/postgres
spring.datasource.username=user
spring.datasource.password=password
spring.datasource.driver-class-name=org.postgresql.Driver

spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect

spring.jpa.hibernate.ddl-auto=update

spring.jpa.show-sql=true

spring.flyway.enabled=true

telegram.bot.base-url=https://api.telegram.org/bot
telegram.bot.token=bottoken
telegram.bot.chat-id=chatid
telegram.bot.alert-template-path=telegram-alert.txt